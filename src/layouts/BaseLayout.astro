---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Container from "../../components/ui/Container.astro";
---

<BaseLayout
  title="Our Companies | S R Group"
  description="Explore the manufacturing companies that form S R Group, delivering industrial chemicals, distilled solvents and unsaturated polyester resins since 1997."
>

<section class="hero">

  <Container>

    <span class="eyebrow">OUR COMPANIES</span>

    <h1>
      Three Manufacturing Companies.<br />
      One Commitment to Quality.
    </h1>

    <p>
      For over two decades, S R Group has expanded its manufacturing
      capabilities through specialised companies serving diverse industrial
      sectors with dependable products, consistent quality and long-term
      partnerships.
    </p>

  </Container>

</section>

<section class="companies">

  <Container>

    <article class="company-card">

      <div class="company-content">

        <span class="company-label">
          Shared Manufacturing
        </span>

        <h2>
          S R Industries &amp; S R Plast
        </h2>

        <p>
          Operating from a common manufacturing facility in Chhatral GIDC,
          S R Industries and S R Plast together manufacture industrial
          chemicals, distilled solvents and chemical products for customers
          across multiple industries.
        </p>

        <ul>

          <li>Industrial Chemicals</li>
          <li>Distilled Solvents</li>
          <li>Chemical Processing</li>
          <li>Packaging Solutions</li>

        </ul>

        <a
          href={`${import.meta.env.BASE_URL}companies/industries`}
          class="button"
        >
          Learn More →
        </a>

      </div>

    </article>

    <article class="company-card">

      <div class="company-content">

        <span class="company-label">
          Resin Manufacturing
        </span>

        <h2>
          S R Polymers
        </h2>

        <p>
          Dedicated to manufacturing unsaturated polyester resins for composite
          industries, S R Polymers combines modern production practices with
          reliable quality and consistent performance.
        </p>

        <ul>

          <li>Unsaturated Polyester Resin</li>
          <li>Composite Applications</li>
          <li>Modern Manufacturing</li>
          <li>Quality Assurance</li>

        </ul>

        <a
          href={`${import.meta.env.BASE_URL}companies/polymers`}
          class="button"
        >
          Learn More →
        </a>

      </div>

    </article>

  </Container>

</section>

<section class="cta">

  <Container>

    <h2>
      Looking for the right manufacturing partner?
    </h2>

    <p>
      Speak with our team to discuss your product requirements and discover
      how S R Group can support your business.
    </p>

    <a
      href={`${import.meta.env.BASE_URL}contact`}
      class="button"
    >
      Contact Us
    </a>

  </Container>

</section>

</BaseLayout>

<style>

.hero{
padding:8rem 0 6rem;
text-align:center;
}

.eyebrow{
display:inline-block;
margin-bottom:1rem;
font-size:.8rem;
font-weight:600;
letter-spacing:.28em;
text-transform:uppercase;
color:var(--color-accent);
}

.hero h1{
margin:0;
font-family:var(--font-heading);
font-size:clamp(2.8rem,5vw,4.5rem);
line-height:1.1;
color:var(--color-primary);
}

.hero p{
max-width:760px;
margin:2rem auto 0;
font-size:1.15rem;
line-height:2;
color:var(--color-text-light);
}

.companies{
padding:2rem 0 7rem;
}

.company-card{
padding:4rem;
border:1px solid var(--color-border);
border-radius:20px;
background:#fff;
margin-bottom:2.5rem;
transition:.3s ease;
}

.company-card:hover{
transform:translateY(-4px);
box-shadow:0 20px 50px rgba(0,0,0,.05);
}

.company-label{
display:inline-block;
margin-bottom:1rem;
font-size:.75rem;
font-weight:600;
letter-spacing:.24em;
text-transform:uppercase;
color:var(--color-accent);
}

.company-content h2{
margin:0 0 1.5rem;
font-family:var(--font-heading);
font-size:2.3rem;
color:var(--color-primary);
}

.company-content p{
margin:0;
font-size:1.08rem;
line-height:2;
color:var(--color-text-light);
max-width:760px;
}

.company-content ul{
display:grid;
grid-template-columns:repeat(2,minmax(220px,1fr));
gap:1rem 2rem;
margin:2.5rem 0;
padding:0;
list-style:none;
}

.company-content li{
position:relative;
padding-left:1.2rem;
}

.company-content li::before{
content:"";
position:absolute;
left:0;
top:.7rem;
width:6px;
height:6px;
border-radius:50%;
background:var(--color-accent);
}

.button{
display:inline-flex;
align-items:center;
justify-content:center;
padding:.95rem 2rem;
border:1px solid var(--color-accent);
border-radius:999px;
text-decoration:none;
font-weight:600;
color:var(--color-primary);
transition:.3s ease;
}

.button:hover{
background:var(--color-accent);
color:#fff;
}

.cta{
padding:3rem 0 8rem;
text-align:center;
}

.cta h2{
margin:0;
font-family:var(--font-heading);
font-size:2.6rem;
color:var(--color-primary);
}

.cta p{
max-width:640px;
margin:1.5rem auto 2.5rem;
font-size:1.1rem;
line-height:1.9;
color:var(--color-text-light);
}

@media (max-width:900px){

.hero{
padding:6rem 0 5rem;
}

.company-card{
padding:2.5rem;
}

.company-content ul{
grid-template-columns:1fr;
}

.company-content h2{
font-size:2rem;
}

.cta{
padding:2rem 0 6rem;
}

.cta h2{
font-size:2rem;
}

}

</style>
