---
import "../styles/global.css";

import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

export interface Props {
  title?: string;
  description?: string;
  canonical?: string;
}

const {
  title = "S R Group | Chemical Manufacturing Since 1997",
  description =
    "S R Group is a family-owned chemical manufacturing group based in Chhatral, Gujarat, serving industrial customers with quality chemical products and manufacturing expertise since 1997.",
  canonical,
} = Astro.props;

const site = "https://1407henil.github.io";
const base = "/srgroup-website";
const pageUrl = canonical ?? `${site}${base}${Astro.url.pathname}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0C0153" />

    <link rel="canonical" href={pageUrl} />
    <link rel="icon" href={`${base}/favicon.svg`} type="image/svg+xml" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:site_name" content="S R Group" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
  </head>

  <body>
    <Header />

    <main>
      <slot />
    </main>

    <Footer />
  </body>
</html>
