---
const base = import.meta.env.BASE_URL;
const path = Astro.url.pathname.replace(base, "/");
const isActive = (href: string) =>
  path === href || path.startsWith(href + "/");
---

<header class="site-header">

  <div class="container">

    <a href={base} class="logo">

      <img
        src={`${base}assets/logo/sr-group.svg`}
        alt="S R Group"
      />

    </a>

    <nav>

      <a
        href={base}
        class:list={[{ active: path === "/" }]}
      >
        Home
      </a>

      <a
        href={`${base}about`}
        class:list={[{ active: isActive("/about") }]}
      >
        About
      </a>

      <a
        href={`${base}companies`}
        class:list={[{ active: isActive("/companies") }]}
      >
        Companies
      </a>

      <a
        href={`${base}products`}
        class:list={[{ active: isActive("/products") }]}
      >
        Products
      </a>

      <a
        href={`${base}contact`}
        class:list={[{ active: isActive("/contact") }]}
      >
        Contact
      </a>

    </nav>

  </div>

</header>

<style>

.site-header{
position:sticky;
top:0;
z-index:1000;
background:rgba(253,249,243,.88);
backdrop-filter:blur(18px);
border-bottom:1px solid rgba(196,154,42,.15);
}

.container{
max-width:1240px;
margin:auto;
padding:1.2rem 2rem;
display:flex;
justify-content:space-between;
align-items:center;
}

.logo img{
height:46px;
display:block;
}

nav{
display:flex;
align-items:center;
gap:2.25rem;
}

nav a{
position:relative;
text-decoration:none;
font-size:.95rem;
font-weight:500;
letter-spacing:.02em;
color:var(--color-primary);
transition:.25s;
}

nav a:hover{
color:var(--color-accent);
}

nav a.active{
color:var(--color-accent);
}

nav a.active::after{
content:"";
position:absolute;
left:0;
right:0;
bottom:-10px;
height:2px;
background:var(--color-accent);
}

@media(max-width:900px){

.container{
padding:1rem 1.25rem;
}

.logo img{
height:38px;
}

nav{
gap:1.2rem;
overflow:auto;
}

nav a{
font-size:.88rem;
white-space:nowrap;
}

}

</style>
