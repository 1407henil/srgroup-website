---
import Container from "./Container.astro";
import { navigation } from "../data/navigation";
---

<header class="site-header">

  <Container>

    <div class="header-inner">

      <a
        href={import.meta.env.BASE_URL}
        class="brand"
        aria-label="S R Group Home"
      >

        <img
          src={`${import.meta.env.BASE_URL}assets/logo/sr-monogram.svg`}
          alt="S R Group"
          class="brand-logo"
        />

        <div class="brand-text">

          <span class="brand-title">
            S R Group
          </span>

          <span class="brand-subtitle">
            EST. 1997
          </span>

        </div>

      </a>

      <nav aria-label="Primary Navigation">

        <ul class="nav-list">

          {
            navigation.map((item) => (

              <li>

                <a href={`${import.meta.env.BASE_URL}${item.href}`}>
                  {item.label}
                </a>

              </li>

            ))
          }

        </ul>

      </nav>

    </div>

  </Container>

</header>

<style>

.site-header{

position:sticky;

top:0;

z-index:100;

background:rgba(253,249,243,.96);

backdrop-filter:blur(12px);

border-bottom:1px solid var(--color-border);

}

.header-inner{

display:flex;

justify-content:space-between;

align-items:center;

min-height:90px;

gap:3rem;

}

.brand{

display:flex;

align-items:center;

gap:14px;

text-decoration:none;

flex-shrink:0;

}

.brand-logo{

width:50px;

height:50px;

display:block;

object-fit:contain;

}

.brand-text{

display:flex;

flex-direction:column;

justify-content:center;

line-height:1;

}

.brand-title{

font-family:var(--font-logo);

font-size:2.3rem;

font-weight:700;

color:var(--color-accent);

letter-spacing:.015em;

transition:var(--transition);

}

.brand:hover .brand-title{

color:#A87F18;

}

.brand-subtitle{

margin-top:.35rem;

font-family:var(--font-body);

font-size:.68rem;

font-weight:600;

letter-spacing:.24em;

text-transform:uppercase;

color:#777;

}

.nav-list{

display:flex;

gap:2.5rem;

margin:0;

padding:0;

list-style:none;

}

.nav-list a{

position:relative;

font-size:.95rem;

font-weight:500;

transition:var(--transition);

}

.nav-list a:hover{

color:var(--color-accent);

}

.nav-list a::after{

content:"";

position:absolute;

left:0;

bottom:-6px;

width:0;

height:1px;

background:var(--color-accent);

transition:var(--transition);

}

.nav-list a:hover::after{

width:100%;

}

@media (max-width:900px){

.nav-list{

display:none;

}

.header-inner{

min-height:82px;

}

.brand-logo{

width:42px;

height:42px;

}

.brand-title{

font-size:1.9rem;

}

.brand-subtitle{

font-size:.62rem;

}

}

</style>
