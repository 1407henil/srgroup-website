---
import Container from "./Container.astro";
import Section from "./Section.astro";
---

<Section class="companies">
  <Container>

    <p class="eyebrow">Our Companies</p>

    <h2>
      Three companies.<br />
      One manufacturing group.
    </h2>

    <div class="company-grid">

      <article class="company-card">
        <h3>S R Industries</h3>

        <p>
          Industrial chemical manufacturing with decades of production
          experience and dependable supply.
        </p>
      </article>

      <article class="company-card">
        <h3>S R Plast</h3>

        <p>
          Supporting manufacturing operations through integrated
          production capabilities and quality-focused processes.
        </p>
      </article>

      <article class="company-card">
        <h3>S R Polymers</h3>

        <p>
          Dedicated manufacturing facility for Unsaturated Polyester
          Resin serving multiple industrial applications.
        </p>
      </article>

    </div>

  </Container>
</Section>

<style>

.companies{
background:#fff;
}

.eyebrow{

color:var(--color-accent);

font-size:.85rem;

font-weight:600;

letter-spacing:.08em;

text-transform:uppercase;

margin-bottom:1rem;

}

.company-grid{

display:grid;

grid-template-columns:repeat(3,1fr);

gap:2rem;

margin-top:4rem;

}

.company-card{

padding:2rem;

border:1px solid var(--color-border);

transition:var(--transition);

}

.company-card:hover{

transform:translateY(-6px);

}

.company-card h3{

margin-bottom:1rem;

}

.company-card p{

color:var(--color-text-light);

}

@media(max-width:900px){

.company-grid{

grid-template-columns:1fr;

}

}

</style>
