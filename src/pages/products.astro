---
import BaseLayout from "../layouts/BaseLayout.astro";
import Container from "../components/ui/Container.astro";

const products = [
  {
    category: "Industrial Solvent",
    title: "SRSolv",
    description:
      "High-performance industrial degreasing solvent developed as an economical alternative for heavy-duty metal cleaning applications.",
    applications: [
      "Metal Degreasing",
      "Bearing Cleaning",
      "Machine Components",
      "Surface Preparation"
    ],
    packaging: "40 kg Carboy • 300 kg HDPE Drum"
  },
  {
    category: "Industrial Chemical",
    title: "Distilled Mono Ethylene Glycol (MEG)",
    description:
      "Purified Mono Ethylene Glycol manufactured with consistent quality for industrial processing applications.",
    applications: [
      "Chemical Processing",
      "Industrial Manufacturing",
      "Cooling Systems",
      "General Industrial Use"
    ],
    packaging: "230 kg Drum • Bulk Supply"
  },
  {
    category: "Industrial Chemical",
    title: "Distilled Diethylene Glycol (DEG)",
    description:
      "High-quality distilled Diethylene Glycol manufactured for customers requiring reliable purity and consistent performance.",
    applications: [
      "Chemical Manufacturing",
      "Industrial Processing",
      "Solvent Applications",
      "Process Industries"
    ],
    packaging: "230 kg Drum • Bulk Supply"
  },
  {
    category: "Composite Resin",
    title: "Unsaturated Polyester Resin",
    description:
      "Premium resin manufactured for FRP and composite industries with dependable quality and batch consistency.",
    applications: [
      "FRP Products",
      "Composite Components",
      "Industrial Moulding",
      "General Composites"
    ],
    packaging: "HDPE Drum"
  }
];
---

<BaseLayout
  title="Products | S R Group"
  description="Industrial chemical products manufactured by S R Group."
>

<section class="hero">

  <Container>

    <span class="eyebrow">
      PRODUCTS
    </span>

    <h1>
      Industrial Chemical<br />
      Product Portfolio
    </h1>

    <p>
      Reliable chemical manufacturing backed by decades of industrial
      experience and consistent quality.
    </p>

  </Container>

</section>

<section class="products">

  <Container>

    {
      products.map((product) => (

        <article class="card">

          <span class="category">
            {product.category}
          </span>

          <h2>
            {product.title}
          </h2>

          <p>
            {product.description}
          </p>

          <div class="divider"></div>

          <h3>
            Applications
          </h3>

          <ul>

            {
              product.applications.map((item) => (

                <li>{item}</li>

              ))
            }

          </ul>

          <div class="packaging">

            <span>Packaging</span>

            <strong>{product.packaging}</strong>

          </div>

        </article>

      ))
    }

  </Container>

</section>

<section class="cta">

  <Container>

    <h2>
      Looking for product specifications?
    </h2>

    <p>
      Contact our team for technical data sheets, packaging information and commercial enquiries.
    </p>

    <a
      href={`${import.meta.env.BASE_URL}contact`}
      class="button"
    >
      Contact Us
    </a>

  </Container>

</section>

</BaseLayout>

<style>

.hero{
padding:8rem 0 6rem;
text-align:center;
}

.eyebrow{
display:inline-block;
margin-bottom:1rem;
font-size:.8rem;
letter-spacing:.28em;
text-transform:uppercase;
font-weight:600;
color:var(--color-accent);
}

.hero h1{
margin:0;
font-family:var(--font-heading);
font-size:clamp(3rem,5vw,4.6rem);
line-height:1.1;
color:var(--color-primary);
}

.hero p{
max-width:720px;
margin:2rem auto 0;
font-size:1.15rem;
line-height:2;
color:var(--color-text-light);
}

.products{
padding:2rem 0 7rem;
}

.products .container{
display:grid;
gap:2rem;
}

.card{
padding:3.5rem;
background:#fff;
border:1px solid var(--color-border);
border-radius:22px;
transition:.3s;
}

.card:hover{
transform:translateY(-4px);
box-shadow:0 18px 40px rgba(0,0,0,.05);
}

.category{
display:inline-block;
margin-bottom:1rem;
font-size:.75rem;
letter-spacing:.24em;
text-transform:uppercase;
font-weight:600;
color:var(--color-accent);
}

.card h2{
margin:0;
font-size:2rem;
font-family:var(--font-heading);
color:var(--color-primary);
}

.card p{
margin:1.5rem 0;
line-height:2;
color:var(--color-text-light);
}

.divider{
width:70px;
height:1px;
background:var(--color-accent);
margin:2rem 0;
}

.card h3{
margin:0 0 1rem;
font-size:1rem;
letter-spacing:.15em;
text-transform:uppercase;
color:var(--color-primary);
}

.card ul{
margin:0;
padding:0;
list-style:none;
display:grid;
grid-template-columns:repeat(2,minmax(220px,1fr));
gap:1rem;
}

.card li{
position:relative;
padding-left:1.2rem;
}

.card li::before{
content:"";
position:absolute;
left:0;
top:.72rem;
width:6px;
height:6px;
border-radius:50%;
background:var(--color-accent);
}

.packaging{
margin-top:2.5rem;
padding-top:1.5rem;
border-top:1px solid var(--color-border);
}

.packaging span{
display:block;
margin-bottom:.4rem;
font-size:.8rem;
letter-spacing:.12em;
text-transform:uppercase;
color:var(--color-accent);
}

.packaging strong{
color:var(--color-primary);
font-weight:600;
}

.cta{
padding:0 0 8rem;
text-align:center;
}

.cta h2{
margin:0;
font-family:var(--font-heading);
font-size:2.5rem;
color:var(--color-primary);
}

.cta p{
max-width:650px;
margin:1.5rem auto 2.5rem;
line-height:1.9;
color:var(--color-text-light);
}

.button{
display:inline-flex;
align-items:center;
justify-content:center;
padding:1rem 2.5rem;
border-radius:999px;
border:1px solid var(--color-accent);
text-decoration:none;
font-weight:600;
color:var(--color-primary);
transition:.3s;
}

.button:hover{
background:var(--color-accent);
color:#fff;
}

@media(max-width:900px){

.hero{
padding:6rem 0 5rem;
}

.card{
padding:2.25rem;
}

.card ul{
grid-template-columns:1fr;
}

.cta h2{
font-size:2rem;
}

}

</style>
