---
import Container from "./Container.astro";
import { navigation } from "../data/navigation";
---

<header class="site-header">

  <Container>

    <div class="header-inner">

      <a
        href={import.meta.env.BASE_URL}
        class="brand"
        aria-label="S R Group Home"
      >

        <img
          src={`${import.meta.env.BASE_URL}assets/logo/1.svg`}
          alt="S R Group"
          class="brand-logo"
        />

        <div class="brand-text">

          <span class="brand-title">
            S R Group
          </span>

          <span class="brand-subtitle">
            ESTABLISHED&nbsp;1997
          </span>

        </div>

      </a>

      <nav aria-label="Primary Navigation">

        <ul class="nav-list">

          {
            navigation.map((item) => (

              <li>

                <a href={`${import.meta.env.BASE_URL}${item.href}`}>
                  {item.label}
                </a>

              </li>

            ))
          }

        </ul>

      </nav>

    </div>

  </Container>

</header>

<style>

.site-header{
position:sticky;
top:0;
z-index:100;
background:rgba(253,249,243,.96);
backdrop-filter:blur(14px);
border-bottom:1px solid var(--color-border);
}

.header-inner{
display:flex;
justify-content:space-between;
align-items:center;
min-height:78px;
gap:2rem;
}

.brand{
display:flex;
align-items:center;
gap:8px;
text-decoration:none;
flex-shrink:0;
transition:var(--transition);
}

.brand-logo{
width:64px;
height:64px;
display:block;
object-fit:contain;
flex-shrink:0;
transition:transform .35s ease;
}

.brand:hover .brand-logo{
transform:scale(1.04);
}

.brand-text{
display:flex;
flex-direction:column;
justify-content:center;
line-height:1;
}

.brand-title{
font-family:var(--font-logo);
font-size:2.12rem;
font-weight:700;
color:var(--color-accent);
letter-spacing:.01em;
transition:var(--transition);
}

.brand:hover .brand-title{
color:#A87F18;
}

.brand-subtitle{
margin-top:.34rem;
font-family:var(--font-body);
font-size:.62rem;
font-weight:600;
letter-spacing:.30em;
text-transform:uppercase;
color:#7A7A7A;
}

.nav-list{
display:flex;
align-items:center;
gap:2.6rem;
margin:0;
padding:0;
list-style:none;
}

.nav-list a{
position:relative;
font-size:1rem;
font-weight:500;
color:var(--color-text);
transition:color .25s ease;
}

.nav-list a:hover{
color:var(--color-accent);
}

.nav-list a::after{
content:"";
position:absolute;
left:0;
bottom:-7px;
width:0;
height:2px;
border-radius:999px;
background:var(--color-accent);
transition:width .25s ease;
}

.nav-list a:hover::after{
width:100%;
}

@media (max-width:900px){

.nav-list{
display:none;
}

.header-inner{
min-height:72px;
}

.brand{
gap:8px;
}

.brand-logo{
width:48px;
height:48px;
}

.brand-title{
font-size:1.75rem;
}

.brand-subtitle{
font-size:.56rem;
letter-spacing:.24em;
}

}

</style>
