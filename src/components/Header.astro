---
import Container from "./Container.astro";
import { navigation } from "../data/navigation";
---

<header class="site-header">

  <Container>

    <div class="header-inner">

      <a
        href={import.meta.env.BASE_URL}
        class="logo"
        aria-label="S R Group Home"
      >

        <span class="wordmark">
          S R Group
        </span>

        <span class="established">
          Est. 1997
        </span>

      </a>

      <nav aria-label="Primary Navigation">

        <ul class="nav-list">

          {
            navigation.map((item) => (
              <li>
                <a href={`${import.meta.env.BASE_URL}${item.href}`}>
                  {item.label}
                </a>
              </li>
            ))
          }

        </ul>

      </nav>

    </div>

  </Container>

</header>

<style>

.site-header{
position:sticky;
top:0;
z-index:100;
background:rgba(253,249,243,.96);
backdrop-filter:blur(12px);
border-bottom:1px solid var(--color-border);
}

.header-inner{
display:flex;
align-items:center;
justify-content:space-between;
min-height:90px;
}

.logo{
display:flex;
flex-direction:column;
justify-content:center;
gap:.15rem;

text-decoration:none;

line-height:1;
}

.wordmark{

font-family:var(--font-logo);

font-size:2.55rem;

font-weight:700;

letter-spacing:.015em;

color:var(--color-accent);

transition:var(--transition);

}

.logo:hover .wordmark{

color:#A87F18;

}

.established{

font-family:var(--font-body);

font-size:.72rem;

font-weight:500;

letter-spacing:.22em;

text-transform:uppercase;

color:#7B7B7B;

margin-left:.12rem;

}

.nav-list{
display:flex;
gap:2.5rem;
margin:0;
padding:0;
list-style:none;
}

.nav-list a{
position:relative;
font-size:.95rem;
font-weight:500;
transition:var(--transition);
text-decoration:none;
}

.nav-list a:hover{
color:var(--color-accent);
}

.nav-list a::after{
content:"";
position:absolute;
left:0;
bottom:-6px;
width:0;
height:1px;
background:var(--color-accent);
transition:var(--transition);
}

.nav-list a:hover::after{
width:100%;
}

@media (max-width:768px){

.header-inner{
min-height:82px;
}

.wordmark{
font-size:2rem;
}

.established{
font-size:.65rem;
}

.nav-list{
display:none;
}

}

</style>
