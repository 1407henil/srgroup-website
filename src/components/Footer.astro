---
import Container from "./Container.astro";
---

<footer class="site-footer">

  <Container>

    <div class="footer-top">

      <div class="footer-brand">

        <img
          src={`${import.meta.env.BASE_URL}assets/logo/sr-group.svg`}
          alt="S R Group"
          class="footer-logo"
        />

        <p class="footer-tagline">
          Chemical Manufacturing Excellence Since 1997.
        </p>

      </div>

      <div class="footer-links">

        <div>

          <h4>Companies</h4>

          <ul>

            <li><a href={`${import.meta.env.BASE_URL}companies/industries`}>S R Industries</a></li>
            <li><a href={`${import.meta.env.BASE_URL}companies/industries`}>S R Plast</a></li>
            <li><a href={`${import.meta.env.BASE_URL}companies/polymers`}>S R Polymers</a></li>

          </ul>

        </div>

        <div>

          <h4>Quick Links</h4>

          <ul>

            <li><a href={import.meta.env.BASE_URL}>Home</a></li>
            <li><a href={`${import.meta.env.BASE_URL}about`}>About</a></li>
            <li><a href={`${import.meta.env.BASE_URL}companies`}>Companies</a></li>
            <li><a href={`${import.meta.env.BASE_URL}products`}>Products</a></li>
            <li><a href={`${import.meta.env.BASE_URL}contact`}>Contact</a></li>

          </ul>

        </div>

        <div>

          <h4>Contact</h4>

          <ul class="contact-list">

            <li>Chhatral GIDC,<br>Gandhinagar, Gujarat, India</li>
            <li>info@srgroup.in</li>
            <li>+91 XXXXX XXXXX</li>

          </ul>

        </div>

      </div>

    </div>

    <div class="footer-bottom">

      <p>
        © {new Date().getFullYear()} S R Group. All Rights Reserved.
      </p>

    </div>

  </Container>

</footer>

<style>

.site-footer{
margin-top:6rem;
background:#0C0153;
color:#F5F5F5;
}

.footer-top{
display:grid;
grid-template-columns:1.25fr 2fr;
gap:5rem;
padding:5rem 0 3rem;
}

.footer-brand{
display:flex;
flex-direction:column;
gap:1.75rem;
}

.footer-logo{
width:260px;
max-width:100%;
height:auto;
}

.footer-tagline{
margin:0;
font-size:1rem;
line-height:1.8;
color:rgba(255,255,255,.78);
max-width:320px;
}

.footer-links{
display:grid;
grid-template-columns:repeat(3,1fr);
gap:3rem;
}

.footer-links h4{
margin:0 0 1.4rem;
font-size:.95rem;
font-weight:600;
letter-spacing:.08em;
text-transform:uppercase;
color:#C49A2A;
}

.footer-links ul{
margin:0;
padding:0;
list-style:none;
display:flex;
flex-direction:column;
gap:.9rem;
}

.footer-links a{
color:rgba(255,255,255,.82);
text-decoration:none;
transition:.25s;
}

.footer-links a:hover{
color:#C49A2A;
}

.contact-list li{
color:rgba(255,255,255,.82);
line-height:1.8;
}

.footer-bottom{
padding:1.6rem 0;
border-top:1px solid rgba(255,255,255,.12);
}

.footer-bottom p{
margin:0;
text-align:center;
font-size:.9rem;
color:rgba(255,255,255,.62);
}

@media (max-width:900px){

.footer-top{
grid-template-columns:1fr;
gap:3rem;
padding:4rem 0 2.5rem;
}

.footer-links{
grid-template-columns:1fr;
gap:2.5rem;
}

.footer-logo{
width:220px;
}

.footer-bottom p{
text-align:left;
}

}

</style>
