---
const products = [
  {
    name: "SRSolv",
    category: "Industrial Cleaning Solvent",
    description:
      "Economical industrial cleaning solvent developed for heavy-duty metal degreasing and component cleaning.",
    applications: [
      "Metal Degreasing",
      "Bearing Cleaning",
      "Machine Parts",
      "Pre-paint Cleaning"
    ],
    packaging: "40 kg Carboy • 300 kg HDPE Drum"
  },
  {
    name: "Distilled Mono Ethylene Glycol",
    category: "Industrial Chemical",
    description:
      "Purified Mono Ethylene Glycol manufactured for industrial processing applications.",
    applications: [
      "Chemical Processing",
      "Industrial Manufacturing",
      "Heat Transfer",
      "General Industry"
    ],
    packaging: "230 kg Drum • Bulk"
  },
  {
    name: "Distilled Diethylene Glycol",
    category: "Industrial Chemical",
    description:
      "Consistent quality Diethylene Glycol supplied for industrial manufacturing requirements.",
    applications: [
      "Chemical Manufacturing",
      "Industrial Processing",
      "Solvent Applications",
      "Process Industry"
    ],
    packaging: "230 kg Drum • Bulk"
  },
  {
    name: "Unsaturated Polyester Resin",
    category: "Composite Resin",
    description:
      "General purpose orthophthalic polyester resin for FRP and composite industries.",
    applications: [
      "FRP Products",
      "Composite Components",
      "Industrial Moulding",
      "General Fabrication"
    ],
    packaging: "HDPE Drum"
  }
];
---

<section class="products">

  <Container>

    <div class="heading">

      <span>OUR PRODUCTS</span>

      <h2>
        Products Engineered for Industrial Performance
      </h2>

    </div>

    <div class="grid">

      {
        products.map((product) => (

          <article class="card">

            <div class="top">

              <span class="category">
                {product.category}
              </span>

              <h3>
                {product.name}
              </h3>

              <p>
                {product.description}
              </p>

            </div>

            <div class="middle">

              <h4>
                Applications
              </h4>

              <ul>

                {
                  product.applications.map((item) => (

                    <li>{item}</li>

                  ))
                }

              </ul>

            </div>

            <div class="bottom">

              <small>
                Packaging
              </small>

              <strong>
                {product.packaging}
              </strong>

            </div>

          </article>

        ))
      }

    </div>

  </Container>

</section>

<style>

.heading{
margin-bottom:4rem;
text-align:center;
}

.heading span{
display:inline-block;
margin-bottom:1rem;
font-size:.75rem;
letter-spacing:.28em;
text-transform:uppercase;
font-weight:600;
color:var(--color-accent);
}

.heading h2{
margin:0;
font-family:var(--font-heading);
font-size:clamp(2.5rem,5vw,4rem);
color:var(--color-primary);
}

.grid{
display:grid;
grid-template-columns:repeat(2,1fr);
gap:2rem;
}

.card{
display:flex;
flex-direction:column;
justify-content:space-between;
padding:3rem;
background:#fff;
border:1px solid var(--color-border);
border-radius:22px;
transition:.3s;
}

.card:hover{
transform:translateY(-6px);
box-shadow:0 24px 50px rgba(0,0,0,.05);
}

.category{
font-size:.72rem;
font-weight:600;
letter-spacing:.24em;
text-transform:uppercase;
color:var(--color-accent);
}

.card h3{
margin:1rem 0;
font-family:var(--font-heading);
font-size:2rem;
color:var(--color-primary);
}

.card p{
line-height:1.9;
color:var(--color-text-light);
}

.middle{
margin:2rem 0;
}

.middle h4{
margin-bottom:1rem;
font-size:.85rem;
letter-spacing:.18em;
text-transform:uppercase;
color:var(--color-primary);
}

.middle ul{
margin:0;
padding:0;
list-style:none;
display:grid;
grid-template-columns:repeat(2,1fr);
gap:.8rem;
}

.middle li{
position:relative;
padding-left:1rem;
}

.middle li::before{
content:"";
position:absolute;
left:0;
top:.65rem;
width:5px;
height:5px;
border-radius:50%;
background:var(--color-accent);
}

.bottom{
padding-top:1.75rem;
border-top:1px solid var(--color-border);
}

.bottom small{
display:block;
margin-bottom:.5rem;
letter-spacing:.12em;
text-transform:uppercase;
color:var(--color-accent);
}

.bottom strong{
font-weight:600;
color:var(--color-primary);
}

@media(max-width:900px){

.grid{
grid-template-columns:1fr;
}

.card{
padding:2rem;
}

.middle ul{
grid-template-columns:1fr;
}

}

</style>
