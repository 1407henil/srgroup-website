---
import BaseLayout from "../layouts/BaseLayout.astro";
import Container from "../components/ui/Container.astro";
---

<BaseLayout
  title="Contact | S R Group"
  description="Contact S R Group for industrial chemical manufacturing enquiries."
>

<section class="hero">

  <Container>

    <span class="eyebrow">
      CONTACT
    </span>

    <h1>
      Start the Conversation
    </h1>

    <p>
      Whether you need industrial chemicals, distilled solvents or polyester
      resins, our team is ready to understand your requirements and provide
      the right manufacturing solution.
    </p>

  </Container>

</section>

<section class="contact">

  <Container>

    <div class="grid">

      <div class="left">

        <span class="section-title">
          GET IN TOUCH
        </span>

        <h2>
          We'd love to hear from you.
        </h2>

        <p>
          Send us your enquiry and our team will get back to you with the
          most suitable solution for your application.
        </p>

        <div class="info">

          <div>

            <small>Email</small>

            <a href="mailto:info@srindp.com">
              info@srindp.com
            </a>

          </div>

          <div>

            <small>Location</small>

            <p>
              Chhatral GIDC,<br />
              Gandhinagar, Gujarat,<br />
              India
            </p>

          </div>

          <div>

            <small>Business Hours</small>

            <p>
              Monday – Saturday<br />
              9:00 AM – 6:00 PM
            </p>

          </div>

        </div>

      </div>

      <div class="right">

        <form>

          <input
            type="text"
            placeholder="Your Name"
          />

          <input
            type="email"
            placeholder="Email Address"
          />

          <input
            type="text"
            placeholder="Company Name"
          />

          <textarea
            rows="6"
            placeholder="Tell us about your requirement..."
          ></textarea>

          <button type="submit">
            Send Enquiry
          </button>

        </form>

      </div>

    </div>

  </Container>

</section>

</BaseLayout>

<style>

.hero{
padding:8rem 0 6rem;
text-align:center;
}

.eyebrow{
display:inline-block;
margin-bottom:1rem;
font-size:.78rem;
letter-spacing:.28em;
text-transform:uppercase;
font-weight:600;
color:var(--color-accent);
}

.hero h1{
margin:0;
font-family:var(--font-heading);
font-size:clamp(3rem,5vw,4.8rem);
line-height:1.08;
color:var(--color-primary);
}

.hero p{
max-width:760px;
margin:2rem auto 0;
font-size:1.15rem;
line-height:2;
color:var(--color-text-light);
}

.contact{
padding:2rem 0 8rem;
}

.grid{
display:grid;
grid-template-columns:1fr 1fr;
gap:5rem;
align-items:start;
}

.section-title{
display:inline-block;
margin-bottom:1rem;
font-size:.75rem;
letter-spacing:.28em;
text-transform:uppercase;
font-weight:600;
color:var(--color-accent);
}

.left h2{
margin:0 0 1.5rem;
font-family:var(--font-heading);
font-size:2.6rem;
color:var(--color-primary);
}

.left>p{
margin-bottom:3rem;
line-height:2;
color:var(--color-text-light);
}

.info{
display:grid;
gap:2rem;
}

.info small{
display:block;
margin-bottom:.75rem;
font-size:.8rem;
letter-spacing:.15em;
text-transform:uppercase;
color:var(--color-accent);
}

.info a,
.info p{
font-size:1.05rem;
line-height:1.9;
text-decoration:none;
color:var(--color-primary);
}

form{
display:grid;
gap:1.25rem;
padding:3rem;
background:#fff;
border:1px solid var(--color-border);
border-radius:24px;
}

input,
textarea{
width:100%;
padding:1rem 1.25rem;
border:1px solid var(--color-border);
border-radius:12px;
font:inherit;
background:#fff;
}

input:focus,
textarea:focus{
outline:none;
border-color:var(--color-accent);
}

button{
padding:1rem;
border:none;
border-radius:999px;
background:var(--color-primary);
color:#fff;
font:inherit;
font-weight:600;
cursor:pointer;
transition:.3s;
}

button:hover{
background:var(--color-accent);
}

@media(max-width:900px){

.hero{
padding:6rem 0 5rem;
}

.grid{
grid-template-columns:1fr;
gap:3rem;
}

.left h2{
font-size:2rem;
}

form{
padding:2rem;
}

}

</style>
