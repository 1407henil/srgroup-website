---
import Container from "../ui/Container.astro";
import SectionHeader from "../ui/SectionHeader.astro";
---

<section class="companies">

  <Container>

    <SectionHeader
      eyebrow="OUR COMPANIES"
      title="A Group Built on Complementary Manufacturing Expertise"
    />

    <div class="companies-grid">

      <article class="company featured">

        <div class="top">

          <span class="year">Since 1997</span>

          <h3>S R Industries &amp; S R Plast</h3>

        </div>

        <p>
          Established as the foundation of S R Group, S R Industries and
          S R Plast operate as an integrated manufacturing operation from
          Chhatral GIDC, Gujarat.
        </p>

        <p>
          Sharing manufacturing facilities, production infrastructure,
          technical expertise and product lines, both companies collectively
          manufacture industrial chemicals and distilled solvents while serving
          customers across diverse industrial sectors.
        </p>

        <ul>

          <li>Industrial Chemicals</li>

          <li>Distilled Solvents</li>

          <li>Integrated Manufacturing</li>

          <li>Quality Controlled Production</li>

        </ul>

      </article>

      <article class="company">

        <div class="top">

          <span class="year">Since 2012</span>

          <h3>S R Polymers</h3>

        </div>

        <p>
          Established to strengthen the group's manufacturing capabilities,
          S R Polymers specialises in the manufacturing of Unsaturated Polyester
          Resins for the composites industry.
        </p>

        <ul>

          <li>UPR Manufacturing</li>

          <li>Composite Industry</li>

          <li>Technical Resin Solutions</li>

        </ul>

      </article>

    </div>

  </Container>

</section>

<style>

.companies{
padding:7rem 0;
}

.companies-grid{
display:grid;
grid-template-columns:2fr 1fr;
gap:2rem;
margin-top:4rem;
}

.company{
padding:2.75rem;
border:1px solid var(--color-border);
background:#fff;
transition:.3s ease;
}

.company:hover{
transform:translateY(-6px);
box-shadow:0 20px 45px rgba(0,0,0,.05);
border-color:var(--color-accent);
}

.featured{
min-height:100%;
}

.top{
margin-bottom:1.5rem;
}

.year{
display:inline-block;
margin-bottom:1rem;
font-size:.82rem;
font-weight:600;
letter-spacing:.15em;
text-transform:uppercase;
color:var(--color-accent);
}

.company h3{
margin:0;
font-size:2rem;
line-height:1.2;
}

.company p{
line-height:1.9;
color:var(--color-text-light);
}

ul{
margin:2rem 0 0;
padding:0;
list-style:none;
display:grid;
gap:.85rem;
}

li{
display:flex;
align-items:center;
gap:.75rem;
font-weight:500;
}

li::before{
content:"";
width:8px;
height:8px;
border-radius:50%;
background:var(--color-accent);
flex-shrink:0;
}

@media(max-width:900px){

.companies{
padding:5rem 0;
}

.companies-grid{
grid-template-columns:1fr;
}

}

</style>
