---
import Container from "../ui/Container.astro";
import SectionHeader from "../ui/SectionHeader.astro";

const milestones = [
  {
    year: "1997",
    title: "Foundation",
    description:
      "S R Industries was established with a commitment to manufacturing quality chemical products and building lasting customer relationships."
  },
  {
    year: "Growth",
    title: "Business Expansion",
    description:
      "The group expanded its manufacturing capabilities, strengthened infrastructure and diversified into multiple product segments."
  },
  {
    year: "2012",
    title: "S R Polymers",
    description:
      "S R Polymers was established to manufacture Unsaturated Polyester Resins, expanding the group's manufacturing portfolio."
  },
  {
    year: "Today",
    title: "S R Group",
    description:
      "Three manufacturing companies working together with a shared focus on quality, reliability and long-term industrial partnerships."
  }
];
---

<section class="timeline">

  <Container>

    <SectionHeader
      eyebrow="OUR JOURNEY"
      title="Milestones That Shaped Our Growth"
    />

    <div class="timeline-list">

      {
        milestones.map((item) => (
          <article class="item">

            <div class="year">
              {item.year}
            </div>

            <div class="dot"></div>

            <div class="content">
              <h3>{item.title}</h3>
              <p>{item.description}</p>
            </div>

          </article>
        ))
      }

    </div>

  </Container>

</section>

<style>

.timeline{
padding:7rem 0;
background:var(--color-surface);
}

.timeline-list{
position:relative;
margin-top:4rem;
}

.timeline-list::before{
content:"";
position:absolute;
left:110px;
top:0;
bottom:0;
width:1px;
background:var(--color-border);
}

.item{
display:grid;
grid-template-columns:90px 40px 1fr;
gap:2rem;
position:relative;
padding:0 0 3.5rem;
align-items:start;
}

.year{
font-family:var(--font-heading);
font-size:1.15rem;
font-weight:600;
color:var(--color-accent);
text-align:right;
padding-top:.15rem;
}

.dot{
width:14px;
height:14px;
border-radius:50%;
background:var(--color-accent);
margin-top:.35rem;
position:relative;
z-index:2;
}

.content h3{
margin:0 0 .8rem;
font-size:1.45rem;
font-weight:600;
}

.content p{
margin:0;
line-height:1.9;
color:var(--color-text-light);
max-width:700px;
}

.item:last-child{
padding-bottom:0;
}

@media(max-width:768px){

.timeline{
padding:5rem 0;
}

.timeline-list::before{
left:18px;
}

.item{
grid-template-columns:20px 1fr;
gap:1.5rem;
padding-bottom:2.75rem;
}

.year{
grid-column:2;
text-align:left;
margin-bottom:.25rem;
}

.dot{
grid-row:1 / span 2;
margin-top:.55rem;
}

.content{
grid-column:2;
}

}

</style>
