---
import Container from "../ui/Container.astro";
import SectionHeader from "../ui/SectionHeader.astro";

const values = [
  {
    title: "Long-Term Relationships",
    description:
      "We believe lasting partnerships are built through trust, consistency and delivering on every commitment."
  },
  {
    title: "Manufacturing Excellence",
    description:
      "Every batch is produced with disciplined process control, technical expertise and continuous quality monitoring."
  },
  {
    title: "Integrity & Transparency",
    description:
      "Honest business practices, transparent communication and dependable service remain at the heart of everything we do."
  },
  {
    title: "Continuous Improvement",
    description:
      "We continually strengthen our manufacturing capabilities, infrastructure and processes to better serve evolving customer requirements."
  }
];
---

<section class="values">

  <Container>

    <SectionHeader
      eyebrow="OUR PRINCIPLES"
      title="The Values That Continue to Guide S R Group"
    />

    <div class="grid">

      {
        values.map((value) => (

          <article class="card">

            <h3>{value.title}</h3>

            <p>{value.description}</p>

          </article>

        ))
      }

    </div>

  </Container>

</section>

<style>

.values{
padding:7rem 0;
background:var(--color-surface);
}

.grid{
display:grid;
grid-template-columns:repeat(2,1fr);
gap:2rem;
margin-top:4rem;
}

.card{
padding:2.5rem;
border:1px solid var(--color-border);
background:#fff;
transition:.3s ease;
}

.card:hover{
transform:translateY(-5px);
border-color:var(--color-accent);
box-shadow:0 18px 40px rgba(0,0,0,.05);
}

.card h3{
margin:0 0 1rem;
font-size:1.5rem;
line-height:1.3;
}

.card p{
margin:0;
line-height:1.9;
color:var(--color-text-light);
}

@media(max-width:900px){

.values{
padding:5rem 0;
}

.grid{
grid-template-columns:1fr;
}

}

</style>
