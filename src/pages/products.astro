---
import BaseLayout from "../layouts/BaseLayout.astro";
import Container from "../components/ui/Container.astro";
---

<BaseLayout
  title="Products | S R Group"
  description="Explore the industrial chemical products manufactured by S R Group."
>

<section class="hero">

  <Container>

    <span class="eyebrow">
      PRODUCTS
    </span>

    <h1>
      Industrial Chemical<br />
      Product Portfolio
    </h1>

    <p>
      S R Group manufactures industrial chemicals, distilled solvents and
      unsaturated polyester resins for customers requiring dependable quality,
      consistency and reliable supply.
    </p>

  </Container>

</section>

<section class="products">

  <Container>

    <article class="product">

      <div class="content">

        <span class="category">
          Distilled Solvent
        </span>

        <h2>
          SRSolv
        </h2>

        <p>
          SRSolv is a high-performance industrial cleaning solvent developed as
          an economical alternative for metal cleaning, degreasing and general
          industrial applications.
        </p>

        <ul>

          <li>Metal Degreasing</li>
          <li>Bearing Cleaning</li>
          <li>Machine Components</li>
          <li>Industrial Cleaning</li>

        </ul>

      </div>

    </article>

    <article class="product">

      <div class="content">

        <span class="category">
          Solvent
        </span>

        <h2>
          Distilled MEG
        </h2>

        <p>
          Distilled Mono Ethylene Glycol supplied with controlled quality for
          industrial processing and manufacturing applications.
        </p>

      </div>

    </article>

    <article class="product">

      <div class="content">

        <span class="category">
          Solvent
        </span>

        <h2>
          Distilled DEG
        </h2>

        <p>
          High-quality Distilled Diethylene Glycol processed for industrial
          customers requiring dependable product consistency.
        </p>

      </div>

    </article>

    <article class="product">

      <div class="content">

        <span class="category">
          Resin
        </span>

        <h2>
          Unsaturated Polyester Resin
        </h2>

        <p>
          Premium polyester resin manufactured for FRP, composite and industrial
          moulding applications.
        </p>

      </div>

    </article>

  </Container>

</section>

<section class="cta">

  <Container>

    <h2>
      Need Technical Information?
    </h2>

    <p>
      Contact our team for product specifications, packaging details and
      commercial enquiries.
    </p>

    <a
      href={`${import.meta.env.BASE_URL}contact`}
      class="button"
    >
      Contact Us
    </a>

  </Container>

</section>

</BaseLayout>

<style>

.hero{
padding:8rem 0 6rem;
text-align:center;
}

.eyebrow{
display:inline-block;
margin-bottom:1rem;
font-size:.8rem;
font-weight:600;
letter-spacing:.28em;
text-transform:uppercase;
color:var(--color-accent);
}

.hero h1{
margin:0;
font-family:var(--font-heading);
font-size:clamp(3rem,5vw,4.6rem);
line-height:1.1;
color:var(--color-primary);
}

.hero p{
max-width:760px;
margin:2rem auto 0;
font-size:1.15rem;
line-height:2;
color:var(--color-text-light);
}

.products{
padding:1rem 0 7rem;
}

.product{
padding:3.5rem;
margin-bottom:2rem;
background:#fff;
border:1px solid var(--color-border);
border-radius:20px;
transition:.3s;
}

.product:hover{
transform:translateY(-4px);
box-shadow:0 20px 45px rgba(0,0,0,.05);
}

.category{
display:inline-block;
margin-bottom:1rem;
font-size:.75rem;
letter-spacing:.24em;
text-transform:uppercase;
font-weight:600;
color:var(--color-accent);
}

.product h2{
margin:0 0 1.5rem;
font-size:2.2rem;
font-family:var(--font-heading);
color:var(--color-primary);
}

.product p{
margin:0;
max-width:760px;
line-height:2;
color:var(--color-text-light);
}

.product ul{
margin:2rem 0 0;
padding:0;
list-style:none;
display:grid;
grid-template-columns:repeat(2,minmax(220px,1fr));
gap:1rem;
}

.product li{
position:relative;
padding-left:1.2rem;
}

.product li::before{
content:"";
position:absolute;
left:0;
top:.7rem;
width:6px;
height:6px;
border-radius:50%;
background:var(--color-accent);
}

.cta{
padding:1rem 0 8rem;
text-align:center;
}

.cta h2{
margin:0;
font-family:var(--font-heading);
font-size:2.6rem;
color:var(--color-primary);
}

.cta p{
max-width:620px;
margin:1.5rem auto 2.5rem;
line-height:1.9;
color:var(--color-text-light);
}

.button{
display:inline-flex;
padding:1rem 2.25rem;
border-radius:999px;
border:1px solid var(--color-accent);
text-decoration:none;
font-weight:600;
color:var(--color-primary);
transition:.3s;
}

.button:hover{
background:var(--color-accent);
color:#fff;
}

@media(max-width:900px){

.hero{
padding:6rem 0 5rem;
}

.product{
padding:2.25rem;
}

.product ul{
grid-template-columns:1fr;
}

.product h2,
.cta h2{
font-size:2rem;
}

}

</style>
