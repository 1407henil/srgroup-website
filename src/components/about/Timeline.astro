---
import Container from "../Container.astro";
import Section from "../Section.astro";

const milestones = [
  {
    year: "1997",
    title: "Foundation",
    description:
      "S R Group was established by the late Shri Ramanbhai Patel together with his sons, Nilesh Patel and Krushi Patel.",
  },
  {
    year: "2012",
    title: "Expansion",
    description:
      "S R Polymers was established, expanding the group's manufacturing capabilities into unsaturated polyester resins.",
  },
  {
    year: "Today",
    title: "Growing Forward",
    description:
      "Three manufacturing companies serving customers across India while steadily expanding into international markets.",
  },
];
---

<Section>
  <Container>

    <div class="section-header">
      <p class="eyebrow">OUR JOURNEY</p>

      <h2>
        Built over decades.<br />
        Strengthened through generations.
      </h2>
    </div>

    <div class="timeline">

      {
        milestones.map((item) => (
          <div class="timeline-item">

            <div class="year">
              {item.year}
            </div>

            <div class="line"></div>

            <div class="content">
              <h3>{item.title}</h3>
              <p>{item.description}</p>
            </div>

          </div>
        ))
      }

    </div>

  </Container>
</Section>

<style>

.section-header{
max-width:700px;
margin-bottom:4rem;
}

.eyebrow{
font-size:.85rem;
font-weight:600;
letter-spacing:.15em;
text-transform:uppercase;
color:var(--color-accent);
margin-bottom:1rem;
}

.timeline{
display:flex;
flex-direction:column;
}

.timeline-item{
display:grid;
grid-template-columns:140px 40px 1fr;
gap:2rem;
padding:2.5rem 0;
}

.timeline-item:not(:last-child){
border-bottom:1px solid var(--color-border);
}

.year{
font-family:var(--font-heading);
font-size:2rem;
font-weight:600;
color:var(--color-primary);
}

.line{
position:relative;
}

.line::before{
content:"";
position:absolute;
left:50%;
top:0;
bottom:0;
width:2px;
background:var(--color-border);
transform:translateX(-50%);
}

.line::after{
content:"";
position:absolute;
left:50%;
top:.4rem;
width:12px;
height:12px;
border-radius:50%;
background:var(--color-accent);
transform:translateX(-50%);
}

.content h3{
margin-bottom:.75rem;
}

.content p{
margin:0;
color:var(--color-text-light);
line-height:1.8;
}

@media(max-width:768px){

.timeline-item{
grid-template-columns:1fr;
gap:1rem;
}

.line{
display:none;
}

}

</style>
