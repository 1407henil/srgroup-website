---
import Container from "../ui/Container.astro";
---

<section class="about-hero">

  <Container>

    <div class="hero-grid">

      <div class="hero-content">

        <p class="eyebrow">
          ABOUT S R GROUP
        </p>

        <h1>
          Building Industrial
          Partnerships Since
          <span>1997</span>
        </h1>

        <p class="intro">
          S R Group is a family-owned chemical manufacturing group based in
          Chhatral, Gujarat, delivering reliable chemical solutions through
          quality manufacturing, technical expertise and long-term customer
          relationships.
        </p>

      </div>

      <div class="hero-meta">

        <div class="meta">
          <span class="value">1997</span>
          <span class="label">Established</span>
        </div>

        <div class="meta">
          <span class="value">Family</span>
          <span class="label">Owned Business</span>
        </div>

        <div class="meta">
          <span class="value">3</span>
          <span class="label">Manufacturing Companies</span>
        </div>

        <div class="meta">
          <span class="value">Chhatral</span>
          <span class="label">Gujarat, India</span>
        </div>

      </div>

    </div>

  </Container>

</section>

<style>

.about-hero{
padding:8rem 0 6rem;
border-bottom:1px solid var(--color-border);
}

.hero-grid{
display:grid;
grid-template-columns:2fr 1fr;
gap:5rem;
align-items:end;
}

.eyebrow{
font-size:.82rem;
font-weight:600;
letter-spacing:.18em;
text-transform:uppercase;
color:var(--color-accent);
margin-bottom:1.25rem;
}

h1{
font-size:clamp(3rem,6vw,5.3rem);
line-height:1.02;
letter-spacing:-.03em;
max-width:820px;
margin:0;
}

h1 span{
display:block;
color:var(--color-accent);
}

.intro{
margin-top:2rem;
max-width:700px;
font-size:1.12rem;
line-height:1.9;
color:var(--color-text-light);
}

.hero-meta{
display:grid;
grid-template-columns:1fr;
gap:1.75rem;
padding-left:2rem;
border-left:1px solid var(--color-border);
}

.meta{
display:flex;
flex-direction:column;
gap:.45rem;
}

.value{
font-family:var(--font-heading);
font-size:1.75rem;
font-weight:600;
color:var(--color-primary);
}

.label{
font-size:.92rem;
line-height:1.6;
color:var(--color-text-light);
}

@media (max-width:900px){

.hero-grid{
grid-template-columns:1fr;
gap:4rem;
}

.hero-meta{
padding-left:0;
padding-top:2rem;
border-left:none;
border-top:1px solid var(--color-border);
grid-template-columns:repeat(2,1fr);
}

}

@media (max-width:640px){

.about-hero{
padding:6rem 0 4rem;
}

.hero-meta{
grid-template-columns:1fr;
}

.intro{
font-size:1rem;
}

}

</style>
