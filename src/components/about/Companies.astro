---
import Container from "../Container.astro";
import Section from "../Section.astro";
---

<Section>

  <Container>

    <div class="section-header">

      <p class="eyebrow">OUR COMPANIES</p>

      <h2>
        Three companies.<br />
        One shared commitment to quality.
      </h2>

    </div>

    <div class="companies">

      <article class="company">

        <h3>S R Industries</h3>

        <p>
          Manufacturing industrial chemicals that serve a wide range of
          industrial applications with a focus on consistent quality and
          dependable supply.
        </p>

      </article>

      <article class="company">

        <h3>S R Plast</h3>

        <p>
          Producing distilled solvents through carefully controlled processing,
          delivering reliable performance for industrial customers across India.
        </p>

      </article>

      <article class="company">

        <h3>S R Polymers</h3>

        <p>
          Manufacturing unsaturated polyester resins for composites,
          construction, marine, automotive and allied industries.
        </p>

      </article>

    </div>

  </Container>

</Section>

<style>

.section-header{
max-width:720px;
margin-bottom:4rem;
}

.eyebrow{
font-size:.85rem;
font-weight:600;
letter-spacing:.15em;
text-transform:uppercase;
color:var(--color-accent);
margin-bottom:1rem;
}

.companies{
display:grid;
grid-template-columns:repeat(3,1fr);
gap:2rem;
}

.company{
padding:2.5rem;
border:1px solid var(--color-border);
transition:.3s ease;
}

.company:hover{
transform:translateY(-6px);
border-color:var(--color-accent);
}

.company h3{
margin-bottom:1rem;
}

.company p{
margin:0;
line-height:1.8;
color:var(--color-text-light);
}

@media(max-width:900px){

.companies{
grid-template-columns:1fr;
}

}

</style>
