---
import Container from "../ui/Container.astro";
import SectionHeader from "../ui/SectionHeader.astro";

const companies = [
  {
    name: "S R Industries",
    year: "1997",
    description:
      "The foundation of S R Group, manufacturing and supplying industrial chemicals with a strong focus on quality, consistency and dependable service.",
    focus: [
      "Industrial Chemicals",
      "Solvents",
      "Chemical Processing"
    ]
  },
  {
    name: "S R Plast",
    year: "2002",
    description:
      "Supporting the group's manufacturing ecosystem with packaging solutions and integrated operations that ensure efficiency and reliability.",
    focus: [
      "HDPE Drums",
      "Industrial Packaging",
      "Manufacturing Support"
    ]
  },
  {
    name: "S R Polymers",
    year: "2012",
    description:
      "Dedicated to manufacturing Unsaturated Polyester Resins for composite manufacturers while continually expanding product capabilities.",
    focus: [
      "UPR Manufacturing",
      "Composite Industry",
      "Resin Solutions"
    ]
  }
];
---

<section class="companies">

  <Container>

    <SectionHeader
      eyebrow="GROUP COMPANIES"
      title="Three Companies. One Shared Commitment."
    />

    <div class="grid">

      {
        companies.map((company) => (

          <article class="card">

            <div class="top">

              <span class="year">
                Since {company.year}
              </span>

              <h3>{company.name}</h3>

            </div>

            <p class="description">
              {company.description}
            </p>

            <ul>

              {
                company.focus.map((item) => (
                  <li>{item}</li>
                ))
              }

            </ul>

          </article>

        ))
      }

    </div>

  </Container>

</section>

<style>

.companies{
padding:7rem 0;
}

.grid{
display:grid;
grid-template-columns:repeat(3,1fr);
gap:2rem;
margin-top:4rem;
}

.card{
display:flex;
flex-direction:column;
padding:2.5rem;
border:1px solid var(--color-border);
background:white;
transition:.3s ease;
height:100%;
}

.card:hover{
transform:translateY(-6px);
border-color:var(--color-accent);
box-shadow:0 18px 40px rgba(0,0,0,.06);
}

.top{
margin-bottom:1.5rem;
}

.year{
display:inline-block;
margin-bottom:1rem;
font-size:.82rem;
letter-spacing:.14em;
text-transform:uppercase;
font-weight:600;
color:var(--color-accent);
}

.card h3{
margin:0;
font-size:1.7rem;
line-height:1.2;
}

.description{
margin:0;
line-height:1.9;
color:var(--color-text-light);
flex:1;
}

ul{
margin:2rem 0 0;
padding:0;
list-style:none;
display:flex;
flex-direction:column;
gap:.8rem;
}

li{
display:flex;
align-items:center;
gap:.75rem;
color:var(--color-primary);
font-weight:500;
}

li::before{
content:"";
width:8px;
height:8px;
border-radius:50%;
background:var(--color-accent);
flex-shrink:0;
}

@media(max-width:1024px){

.grid{
grid-template-columns:1fr;
}

}

@media(max-width:768px){

.companies{
padding:5rem 0;
}

.card{
padding:2rem;
}

}

</style>
