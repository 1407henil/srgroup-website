---
import Container from "./Container.astro";
---

<footer class="site-footer">

  <Container>

    <div class="footer-main">

      <div class="footer-brand">

        <img
          src={`${import.meta.env.BASE_URL}assets/logo/sr-group.svg`}
          alt="S R Group"
          class="footer-logo"
        />

        <p class="footer-tagline">
          Chemical Manufacturing Excellence Since 1997.
        </p>

      </div>

      <div class="footer-columns">

        <div class="footer-column">

          <h4>Companies</h4>

          <ul>

            <li>
              <a href={`${import.meta.env.BASE_URL}companies/industries`}>
                S R Industries
              </a>
            </li>

            <li>
              <a href={`${import.meta.env.BASE_URL}companies/industries`}>
                S R Plast
              </a>
            </li>

            <li>
              <a href={`${import.meta.env.BASE_URL}companies/polymers`}>
                S R Polymers
              </a>
            </li>

          </ul>

        </div>

        <div class="footer-column">

          <h4>Explore</h4>

          <ul>

            <li><a href={`${import.meta.env.BASE_URL}products`}>Products</a></li>
            <li><a href={`${import.meta.env.BASE_URL}industries`}>Industries Served</a></li>
            <li><a href={`${import.meta.env.BASE_URL}infrastructure`}>Infrastructure</a></li>
            <li><a href={`${import.meta.env.BASE_URL}quality`}>Quality Assurance</a></li>
            <li><a href={`${import.meta.env.BASE_URL}downloads`}>Downloads</a></li>

          </ul>

        </div>

        <div class="footer-column">

          <h4>Contact</h4>

          <ul class="contact-list">

            <li>
              <a href="mailto:info@srindp.com">
                info@srindp.com
              </a>
            </li>

            <li>
              Chhatral GIDC,<br>
              Gandhinagar, Gujarat
            </li>

            <li>
              <a href={`${import.meta.env.BASE_URL}contact`}>
                Get in touch →
              </a>
            </li>

          </ul>

        </div>

      </div>

    </div>

    <div class="footer-bottom">

      <span>
        © {new Date().getFullYear()} S R Group. All rights reserved.
      </span>

      <span>
        S R Industries &nbsp;•&nbsp; S R Plast &nbsp;•&nbsp; S R Polymers
      </span>

    </div>

  </Container>

</footer>

<style>

.site-footer{
margin-top:6rem;
padding:5.5rem 0 2rem;
background:var(--color-bg);
border-top:1px solid rgba(196,154,42,.28);
}

.footer-main{
display:grid;
grid-template-columns:1.35fr 2fr;
gap:7rem;
align-items:start;
}

.footer-brand{
display:flex;
flex-direction:column;
}

.footer-logo{
width:360px;
max-width:100%;
height:auto;
display:block;
}

.footer-tagline{
margin:2rem 0 0;
font-size:1rem;
color:var(--color-text-light);
white-space:nowrap;
}

.footer-columns{
display:grid;
grid-template-columns:repeat(3,1fr);
gap:4rem;
}

.footer-column h4{
display:flex;
align-items:center;
gap:.65rem;
margin:0 0 1.8rem;
font-size:.78rem;
font-weight:600;
letter-spacing:.32em;
text-transform:uppercase;
color:var(--color-accent);
}

.footer-column h4::before{
content:"";
width:28px;
height:1px;
background:var(--color-accent);
opacity:.7;
}

.footer-column ul{
margin:0;
padding:0;
list-style:none;
display:flex;
flex-direction:column;
gap:1rem;
}

.footer-column li{
font-size:1.08rem;
line-height:1.8;
color:var(--color-text);
}

.footer-column a{
color:inherit;
text-decoration:none;
transition:.25s ease;
}

.footer-column a:hover{
color:var(--color-accent);
}

.contact-list{
gap:1.35rem;
}

.footer-bottom{
margin-top:4.5rem;
padding-top:1.5rem;
border-top:1px dashed rgba(196,154,42,.45);
display:flex;
justify-content:space-between;
align-items:center;
gap:2rem;
font-size:.92rem;
color:#6D7090;
}

@media (max-width:1000px){

.footer-main{
grid-template-columns:1fr;
gap:4rem;
}

.footer-columns{
grid-template-columns:1fr;
gap:3rem;
}

.footer-tagline{
white-space:normal;
}

.footer-bottom{
flex-direction:column;
align-items:flex-start;
}

.footer-logo{
width:300px;
}

}

</style>
